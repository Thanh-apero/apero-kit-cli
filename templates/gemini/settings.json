{
  "$schema": "https://raw.githubusercontent.com/google-gemini/gemini-cli/main/schemas/settings.schema.json",
  "general": {
    "vimMode": false,
    "defaultApprovalMode": "default",
    "enableAutoUpdate": true,
    "enableNotifications": true,
    "maxAttempts": 5,
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d"
    },
    "checkpointing": {
      "enabled": true
    }
  },
  "ui": {
    "autoThemeSwitching": true,
    "hideBanner": false,
    "hideTips": false,
    "showLineNumbers": true,
    "showCitations": true,
    "showModelInfoInChat": false,
    "inlineThinkingMode": "full",
    "loadingPhrases": "tips",
    "errorVerbosity": "full"
  },
  "model": {
    "name": "gemini-2.5-pro",
    "maxSessionTurns": -1,
    "compressionThreshold": 0.8,
    "disableLoopDetection": false
  },
  "tools": {
    "sandbox": false,
    "shell": {
      "enableInteractiveShell": true,
      "showColor": true,
      "inactivityTimeout": 300
    },
    "useRipgrep": true,
    "truncateToolOutputThreshold": 40000,
    "allowed": [
      "run_shell_command(git)",
      "run_shell_command(npm)",
      "run_shell_command(npx)",
      "run_shell_command(node)",
      "run_shell_command(pnpm)",
      "run_shell_command(yarn)",
      "run_shell_command(bun)",
      "run_shell_command(cat)",
      "run_shell_command(ls)",
      "run_shell_command(pwd)",
      "run_shell_command(echo)",
      "run_shell_command(grep)",
      "run_shell_command(find)",
      "run_shell_command(head)",
      "run_shell_command(tail)",
      "run_shell_command(wc)",
      "run_shell_command(mkdir)",
      "run_shell_command(touch)",
      "run_shell_command(cp)",
      "run_shell_command(mv)",
      "run_shell_command(rm)",
      "run_shell_command(chmod)",
      "run_shell_command(python)",
      "run_shell_command(pip)",
      "run_shell_command(pytest)",
      "run_shell_command(go)",
      "run_shell_command(cargo)",
      "run_shell_command(rustc)",
      "run_shell_command(docker)",
      "run_shell_command(gh)"
    ]
  },
  "context": {
    "fileName": ["GEMINI.md", "AGENTS.md"],
    "includeDirectoryTree": true,
    "discoveryMaxDirs": 200,
    "fileFiltering": {
      "respectGitIgnore": true,
      "respectGeminiIgnore": true,
      "enableFuzzySearch": true
    }
  },
  "security": {
    "disableYoloMode": false,
    "enablePermanentToolApproval": true,
    "folderTrust": {
      "enabled": true
    },
    "environmentVariableRedaction": {
      "enabled": true,
      "blocked": ["API_KEY", "SECRET", "PASSWORD", "TOKEN", "PRIVATE_KEY"]
    }
  },
  "privacy": {
    "usageStatisticsEnabled": false
  },
  "experimental": {
    "enableAgents": true
  }
}
